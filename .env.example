# Anthropic API key — get one at https://console.anthropic.com
# (This is your own billed API key, separate from claude.ai. Required.)
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — get one free at https://resend.com
RESEND_API_KEY=re_...

# Comma-separated list of emails who should get lead notifications
# (e.g. the firm owner + the case manager who handles intake)
NOTIFY_EMAILS=owner@example.com,casemanager@example.com

# The "from" address for notification emails. Must be on a domain you've
# verified in Resend. Until you verify your own domain, you can use
# Resend's shared test address for development: onboarding@resend.dev
NOTIFY_FROM=Intake Assistant <intake@yourfirm.com>

# Customize per client — used inside the AI's system prompt
FIRM_NAME=Vegas Injury Partners
CALLBACK_WINDOW=within one business hour (or first thing the next business day if it's after hours)
